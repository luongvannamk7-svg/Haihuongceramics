# ============================================
# HẢI HƯƠNG CERAMICS - Environment Variables
# Copy file này thành .env.local và điền giá trị thực
# ============================================

# Admin panel password
ADMIN_SECRET=haihuong2025admin

# SMTP Email (Hostinger Email hoặc Gmail App Password)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@haihuongceramics.vn
SMTP_PASS=your_email_password_here

# Email nhận thông báo
CONTACT_EMAIL=sales@haihuongceramics.vn

# MySQL Database (Hostinger)
DATABASE_URL="mysql://username:password@localhost:3306/haihuong_ceramics"

# App URL
NEXTAUTH_URL=https://haihuongceramics.vn
NODE_ENV=production
